modules = ["nodejs-20", "python-3.12", "web"]

[deployment]
router = "application"
deploymentTarget = "vm"
run = ["bash", "-c", "PYTHONPATH=/home/runner/workspace .venv/bin/python -m uvicorn apps.api.main:app --host 127.0.0.1 --port 8000 & PORT=8080 NODE_ENV=production node --enable-source-maps artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "bash scripts/build.sh"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Python API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Node API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AYZEN Dashboard"

[[workflows.workflow]]
name = "Python API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PYTHONPATH=/home/runner/workspace WATCHFILES_IGNORE_PATHS=/home/runner/workspace/node_modules,/home/runner/workspace/.venv,/home/runner/workspace/artifacts/dashboard/node_modules,/home/runner/workspace/artifacts/api-server/node_modules /home/runner/workspace/.venv/bin/python -m uvicorn apps.api.main:app --host 0.0.0.0 --port 8000 --reload --reload-exclude '*.log' --reload-exclude 'node_modules' --reload-exclude '.venv'"
waitForPort = 8000

[[workflows.workflow]]
name = "Node API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 NODE_ENV=development node --enable-source-maps /home/runner/workspace/artifacts/api-server/dist/index.mjs"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "AYZEN Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/dashboard run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 23183
externalPort = 3001

[userenv]

[userenv.shared]
INTERNAL_WEBHOOK_TOKEN = "516a682164f567910ac4940dfa331be4aaba8f57081494922ef22b2046b41701"
TELEGRAM_WEBHOOK_SECRET = "6b309cc2227a0c8853f7702bda5c91e77475a7b9709d7ebab0dfd35d491d239c"
CORS_ORIGINS = "https://${REPLIT_DEV_DOMAIN},https://${REPLIT_DOMAINS}"
ALLOWED_HOSTS = "*"
STATELESS_MODE = "false"
BOT_USERNAME = "AyzenBot"
DEFAULT_QUIET_START = "23:00"
DEFAULT_QUIET_END = "07:00"
REDIS_URL = "redis://localhost:6379/0"
UV_SYSTEM_PYTHON = "0"
UV_PROJECT_ENVIRONMENT = ".venv"

[userenv.development]
ENVIRONMENT = "development"

[userenv.production]
ENVIRONMENT = "production"

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "postgresql", "rustc"]
